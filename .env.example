# Copy to .env for local overrides. .env is gitignored.

# PostgreSQL (docker-compose postgres service)
CONTEXT_PG_HOST=127.0.0.1
CONTEXT_PG_PORT=5432
CONTEXT_PG_USER=context
CONTEXT_PG_PASSWORD=context
CONTEXT_PG_DATABASE=context
CONTEXT_PG_SSLMODE=disable

# Optional DSN override (wins over discrete host/port/user fields when set)
# CONTEXT_PG_DSN=postgres://context:context@127.0.0.1:5432/context?sslmode=disable

# PoC dense embedding contract (fake HashEmbed until a live model adapter)
CONTEXT_EMBEDDING_VERSION=fake-hash-v1
CONTEXT_EMBEDDING_DIMENSION=8
CONTEXT_VECTOR_METRIC=cosine
CONTEXT_VECTOR_COLLECTION=context_dense_v1

# Artifact root for localfs ArtifactStore (CLI --data often overrides)
CONTEXT_ARTIFACT_ROOT=.context/artifacts

# Optional: upsert dense on ingest + enable dense hybrid search
# CONTEXT_ENABLE_DENSE=1
# CONTEXT_DENSE_REBUILD=1

# Optional: live Postgres FTS sparse (default: memory/fake term-overlap)
# CONTEXT_SPARSE_KIND=postgres_fts

# Optional: durable metadata in Postgres (default: memory + state.json)
# CONTEXT_METADATA_KIND=postgres
